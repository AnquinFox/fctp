---
// TraditionalSection.astro — "5000 Years of China" — Scenic Spots
const scenicSpots = [
  {
    name: 'Forbidden City',
    slug: 'forbidden_city',
    tagline: 'Dragon Throne of 24 Emperors',
    era: 'Ming-Qing · 600 years',
    detail: '980 buildings, 8,886 rooms — the largest palace complex on Earth.',
    accent: '#8b1a1a',
    cover: '/images/forbidden_city/forbidden_city_aerial_view_palace_complex_001.webp',
  },
  {
    name: 'Great Wall',
    slug: 'great_wall',
    tagline: '10,000 Li in Stone and Flesh',
    era: 'Warring States–Ming · 2,300 years',
    detail: 'Over 21,000 km snaking across mountains, deserts, and grasslands.',
    accent: '#5c3d1a',
    cover: '/images/great_wall/great_wall_snaking_mountains_aerial_view_001.webp',
  },
  {
    name: 'Terracotta Warriors',
    slug: 'terracotta_warriors',
    tagline: '8,000 Soldiers Guarding Eternity',
    era: 'Qin Dynasty · 2,200 years',
    detail: 'Every face unique. Buried for 2 millennia with China\'s first emperor.',
    accent: '#a0522d',
    cover: '/images/terracotta_warriors/terracotta_warriors_pit_one_thousands_soldiers_001.webp',
  },
  {
    name: 'Mogao Caves',
    slug: 'mogao_caves',
    tagline: '1,000 Years of Buddhist Art',
    era: 'Silk Road · 1,600 years',
    detail: '492 caves, 45,000 m² of murals — a gallery carved into a desert cliff.',
    accent: '#2d5a3d',
    cover: '/images/mogao_caves/mogao_caves_cliffside_grottoes_nine_story_001.webp',
  },
  {
    name: 'Potala Palace',
    slug: 'potala_palace',
    tagline: 'Sanctuary at the Roof of the World',
    era: 'Tibetan Buddhism · 1,300 years',
    detail: 'Perched at 3,700 m in Lhasa — the highest ancient palace on Earth.',
    accent: '#6b3a5b',
    cover: '/images/potala_palace/potala_red_white_palace_mountain_001.webp',
  },
  {
    name: 'Yellow Mountain',
    slug: 'huangshan',
    tagline: 'The Peak That Inspired a Thousand Scrolls',
    era: 'Natural Wonder · 100 million years',
    detail: 'Granite pillars piercing a sea of clouds — the soul of Chinese landscape painting.',
    accent: '#3a5a3a',
    cover: '/images/huangshan/huangshan_sea_of_clouds_mountain_sunrise_002.webp',
  },
];
---

<section class="traditional-section">
  <!-- Decorative top border -->
  <div class="trad-border-top"></div>

  <div class="trad-inner">
    <div class="trad-header">
      <div class="trad-seal">史</div>
      <p class="trad-eyebrow">FIVE THOUSAND YEARS OF CIVILIZATION</p>
      <h2 class="trad-title">China of<br />Five Thousand Years</h2>
      <p class="trad-desc">
        Walk through palace gates that once only emperors could enter.
        Stand before armies frozen in clay for two thousand years.
        These monuments are not museum exhibits — they are time machines.
      </p>
    </div>

    <div class="trad-grid">
      {scenicSpots.map(spot => (
        <a href={`/guides/${spot.slug}/`} class="trad-card" style={`--spot-accent: ${spot.accent}`}>
          <div class="trad-card-border">
            <div class="trad-card-corner tl"></div>
            <div class="trad-card-corner tr"></div>
            <div class="trad-card-corner bl"></div>
            <div class="trad-card-corner br"></div>
          </div>
          <div class="trad-card-img-wrap">
            <img src={spot.cover} alt={spot.name} class="trad-card-img" loading="lazy" />
          </div>
          <div class="trad-card-content">
            <div class="trad-card-header-row">
              <h3 class="trad-card-name">{spot.name}</h3>
              <span class="trad-card-era">{spot.era}</span>
            </div>
            <p class="trad-card-tagline">{spot.tagline}</p>
            <p class="trad-card-detail">{spot.detail}</p>
            <span class="trad-card-explore">Enter the past &rarr;</span>
          </div>
        </a>
      ))}
    </div>

    <div class="trad-footer-note">
      <span class="trad-divider">✦</span>
      <p>Each monument has a dedicated guide: history, best times to visit, ticket tips, and what not to miss.</p>
      <a href="/guides/" class="trad-explore-link">Explore All Destinations →</a>
    </div>
  </div>

  <div class="trad-border-bottom"></div>
</section>

<style>
  .traditional-section {
    position: relative;
    background:
      linear-gradient(175deg,
        #f5e6c8 0%,
        #eed9b4 15%,
        #f2dfbf 30%,
        #e8d3a8 50%,
        #f0dbb8 70%,
        #ebd2a5 85%,
        #f4e2c2 100%
      ),
      repeating-linear-gradient(
        2deg,
        transparent,
        transparent 2px,
        rgba(139, 90, 43, 0.02) 2px,
        rgba(139, 90, 43, 0.02) 4px
      );
    color: #3d2b1a;
    overflow: hidden;
  }

  .traditional-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 10% 20%, rgba(160, 100, 40, 0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 90% 80%, rgba(160, 100, 40, 0.10) 0%, transparent 60%),
      radial-gradient(ellipse at 50% 50%, rgba(139, 69, 19, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .trad-border-top,
  .trad-border-bottom {
    height: 6px;
    background: repeating-linear-gradient(
      90deg,
      #8b5a2b 0px,
      #8b5a2b 8px,
      #c4a35a 8px,
      #c4a35a 16px,
      #a0764a 16px,
      #a0764a 20px,
      transparent 20px,
      transparent 24px
    );
    opacity: 0.6;
  }

  .trad-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 100px 2rem 80px;
    position: relative;
    z-index: 1;
  }

  .trad-header {
    text-align: center;
    margin-bottom: 72px;
  }

  .trad-seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: #8b1a1a;
    color: #f5e6c8;
    font-size: 1.6rem;
    font-weight: 900;
    font-family: "Noto Serif SC", "SimSun", "STSong", serif;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    box-shadow: 2px 2px 0 rgba(139, 26, 26, 0.3);
    transform: rotate(-2deg);
  }

  .trad-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: #8b5a2b;
    margin-bottom: 1rem;
  }

  .trad-title {
    font-family: "Noto Serif SC", "Georgia", "Times New Roman", serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.15;
    color: #3d2b1a;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .trad-desc {
    font-family: "Georgia", "Noto Serif SC", serif;
    font-size: 1.1rem;
    color: #6b4d2f;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.7;
    font-style: italic;
  }

  .trad-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .trad-card {
    position: relative;
    background: linear-gradient(175deg,
      rgba(245, 230, 200, 0.7) 0%,
      rgba(235, 215, 175, 0.8) 100%
    );
    border: 1.5px solid #c4a35a;
    border-radius: 2px;
    padding: 0 1.75rem 2rem 1.75rem;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }

  .trad-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(139, 90, 43, 0.18);
    border-color: var(--spot-accent, #8b5a2b);
  }

  /* Card image */
  .trad-card-img-wrap {
    margin: 0 -1.75rem 1.25rem -1.75rem;
    height: 180px;
    overflow: hidden;
    border-radius: 2px 2px 0 0;
    border-bottom: 2px solid #c4a35a;
  }

  .trad-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: sepia(30%) saturate(80%) brightness(0.9);
    transition: filter 0.3s, transform 0.4s;
  }

  .trad-card:hover .trad-card-img {
    filter: sepia(15%) saturate(100%) brightness(1);
    transform: scale(1.05);
  }

  /* Corner decorations */
  .trad-card-border {
    position: absolute;
    inset: -3px;
    pointer-events: none;
  }

  .trad-card-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: #8b5a2b;
    border-style: solid;
    transition: border-color 0.25s;
  }
  .trad-card-corner.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .trad-card-corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .trad-card-corner.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .trad-card-corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

  .trad-card:hover .trad-card-corner {
    border-color: var(--spot-accent, #8b5a2b);
  }

  .trad-card-content {
    position: relative;
  }

  .trad-card-header-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
    gap: 0.5rem;
  }

  .trad-card-name {
    font-family: "Noto Serif SC", "Georgia", serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #3d2b1a;
    margin: 0;
  }

  .trad-card-era {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--spot-accent, #8b5a2b);
    background: rgba(196, 163, 90, 0.25);
    padding: 0.2em 0.6em;
    border-radius: 3px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .trad-card-tagline {
    font-family: "Georgia", serif;
    font-size: 0.92rem;
    color: #8b5a2b;
    font-style: italic;
    margin-bottom: 0.6rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px dotted #c4a35a;
  }

  .trad-card-detail {
    font-size: 0.82rem;
    color: #6b4d2f;
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .trad-card-explore {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #8b1a1a;
    letter-spacing: 0.05em;
    transition: color 0.2s, transform 0.2s;
  }

  .trad-card:hover .trad-card-explore {
    color: var(--spot-accent, #5c1111);
    transform: translateX(3px);
  }

  .trad-footer-note {
    text-align: center;
    margin-top: 64px;
  }

  .trad-divider {
    display: block;
    color: #c4a35a;
    font-size: 1.4rem;
    margin-bottom: 1.25rem;
  }

  .trad-footer-note p {
    font-family: "Georgia", serif;
    font-size: 1rem;
    color: #6b4d2f;
    margin-bottom: 1rem;
  }

  .trad-explore-link {
    display: inline-block;
    font-family: "Georgia", serif;
    color: #8b1a1a;
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    border-bottom: 1.5px solid #8b1a1a;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .trad-explore-link:hover {
    color: #5c1111;
    border-color: #5c1111;
  }

  @media (max-width: 640px) {
    .trad-inner {
      padding: 60px 1.25rem 50px;
    }
    .trad-grid {
      grid-template-columns: 1fr;
    }
    .trad-card-header-row {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
