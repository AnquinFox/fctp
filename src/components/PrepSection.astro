---
// PrepSection.astro — Collapsible "Before You Land" section
// Renders foreigners survival-kit guides from content collection

export interface Props {
  guides: any[];
  firstGuideSlug?: string;
}

const { guides, firstGuideSlug } = Astro.props;

// Reorder: put firstGuideSlug at the top if specified
let sortedGuides = [...guides];
if (firstGuideSlug) {
  const idx = sortedGuides.findIndex((g: any) => g.data.pageSlug === firstGuideSlug);
  if (idx > 0) {
    const [first] = sortedGuides.splice(idx, 1);
    sortedGuides.unshift(first);
  }
}

// Topic icon map
const topicIcons: Record<string, string> = {
  visa: '🛂',
  entry: '🛂',
  passport: '🛂',
  payment: '💳',
  alipay: '💳',
  wechat: '💳',
  internet: '🌐',
  vpn: '🌐',
  esim: '🌐',
  apps: '📱',
  essential: '📱',
  transport: '🚇',
  metro: '🚇',
  taxi: '🚇',
  health: '🏥',
  emergency: '🏥',
  hospital: '🏥',
  culture: '🎭',
  food: '🎭',
  etiquette: '🎭',
  overview: '📋',
  language: '🗣️',
};

function getIcon(guide: any): string {
  const tags = guide.data.tags || [];
  for (const tag of tags) {
    if (topicIcons[tag]) return topicIcons[tag];
  }
  return '📌';
}

// Extract first meaningful paragraph from body
function extractExcerpt(body: string, maxLen = 100): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    if (trimmed.startsWith('#')) continue;
    if (trimmed.startsWith('![')) continue;
    if (trimmed.startsWith('|')) continue;
    if (trimmed.startsWith('>')) continue;
    if (trimmed.startsWith('-')) continue;
    if (trimmed.startsWith('*')) continue;
    const clean = trimmed.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*/g, '');
    if (clean.length > maxLen) return clean.slice(0, maxLen).trimEnd() + '…';
    return clean;
  }
  return '';
}

// Exclude the index/overview page from cards
const displayGuides = sortedGuides.filter((g: any) => g.data.pageSlug !== 'foreigners-index');
---

<section class="prep-section">
  <!-- Toggle bar — always visible -->
  <button class="prep-toggle-bar" id="prepToggleBar" aria-expanded="true" aria-controls="prepBody">
    <div class="prep-toggle-bar-inner">
      <div class="prep-toggle-left">
        <span class="prep-toggle-icon" id="prepToggleIcon">
          <svg width="18" height="10" viewBox="0 0 18 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L9 9L17 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="prep-toggle-label">疑难杂症 · Survival Kit</span>
        <span class="prep-toggle-count">{displayGuides.length} guides</span>
      </div>
      <span class="prep-toggle-hint" id="prepToggleHint">click to collapse ↑</span>
    </div>
  </button>

  <!-- Collapsible body -->
  <div class="prep-body" id="prepBody">
    <div class="prep-header">
      <p class="prep-eyebrow">BEFORE YOU LAND</p>
      <h2 class="prep-title">What every foreigner<br />needs before China</h2>
      <p class="prep-subtitle">
        From internet access to payments to cultural survival — everything sorted.
        Read these before you book your flight.
      </p>
    </div>

    <div class="prep-grid">
      {displayGuides.map((guide: any, i: number) => {
        const { title, pageSlug, cover, tags } = guide.data;
        const excerpt = extractExcerpt(guide.body);
        const icon = getIcon(guide);
        const isFirst = i === 0;
        return (
          <a href={`/guides/${pageSlug}/`} class={`prep-card${isFirst ? ' prep-card-featured' : ''}`}>
            {isFirst && <span class="prep-card-badge">🥇 TOP READ</span>}
            <div class="prep-card-img-wrap">
              {cover ? (
                <img src={cover} alt={title} class="prep-card-img" loading="lazy" />
              ) : (
                <div class="prep-card-img-placeholder">{icon}</div>
              )}
            </div>
            <div class="prep-card-body">
              <h3 class="prep-card-title">
                <span class="prep-card-icon">{icon}</span>
                {title}
              </h3>
              {excerpt && <p class="prep-card-desc">{excerpt}</p>}
              <div class="prep-card-tags">
                {tags.filter((t: string) => t !== 'survival-kit').map((tag: string) => (
                  <span class="prep-tag">{tag}</span>
                ))}
              </div>
            </div>
            <span class="prep-arrow">→</span>
          </a>
        );
      })}
    </div>

    <div class="prep-cta">
      <a href="/guides/foreigners/foreigners-index/" class="prep-cta-btn">📋 Full Survival Kit</a>
      <span class="prep-cta-time">⏱️ {displayGuides.length} guides</span>
    </div>
  </div>
</section>

<style>
  .prep-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ===== TOGGLE BAR ===== */
  .prep-toggle-bar {
    width: 100%;
    background: #1a1a2e;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 0;
    cursor: pointer;
    position: relative;
    z-index: 10;
    transition: border-radius 0.35s, border-color 0.2s;
    outline: none;
    font: inherit;
    color: inherit;
    text-align: left;
  }

  .prep-toggle-bar:hover {
    border-color: rgba(255, 255, 255, 0.18);
  }

  .prep-toggle-bar[aria-expanded="true"] {
    border-radius: 12px 12px 0 0;
    border-bottom-color: transparent;
  }

  .prep-toggle-bar[aria-expanded="false"] {
    border-radius: 12px;
  }

  .prep-toggle-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  .prep-toggle-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .prep-toggle-icon {
    color: #00f0ff;
    transition: transform 0.35s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
  }

  .prep-toggle-bar[aria-expanded="false"] .prep-toggle-icon {
    transform: rotate(-90deg);
  }

  .prep-toggle-label {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .prep-toggle-count {
    font-size: 0.72rem;
    color: #666;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.2em 0.7em;
    border-radius: 50px;
    font-weight: 500;
  }

  .prep-toggle-hint {
    font-size: 0.7rem;
    color: #555;
    letter-spacing: 0.03em;
    transition: opacity 0.25s;
  }

  .prep-toggle-bar[aria-expanded="false"] .prep-toggle-hint {
    opacity: 0.6;
  }

  /* ===== COLLAPSIBLE BODY ===== */
  .prep-body {
    overflow: hidden;
    max-height: 4000px;
    opacity: 1;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s ease,
                padding 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                margin 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    background: #fff;
    border: 1px solid #e5e5e5;
    border-top: none;
    border-radius: 0 0 12px 12px;
    padding: 36px 2rem 44px;
    margin-bottom: 40px;
  }

  .prep-body.collapsed {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    margin-bottom: 0;
    border-width: 0;
  }

  /* ===== HEADER ===== */
  .prep-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .prep-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #999;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
  }

  .prep-title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #111;
    margin-bottom: 1rem;
  }

  .prep-subtitle {
    font-size: 0.95rem;
    color: #888;
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ===== CARD GRID ===== */
  .prep-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .prep-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: #fff;
    text-decoration: none;
    color: inherit;
    border: 1px solid #eee;
    border-radius: 12px;
    position: relative;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }

  .prep-card:hover {
    border-color: #ddd;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }

  /* Featured card (first — internet guide) */
  .prep-card-featured {
    border-color: #c4e0ff;
    background: linear-gradient(135deg, #f8fbff 0%, #fff 100%);
  }

  .prep-card-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: #1a73e8;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.35em 0.9em;
    border-radius: 0 12px 0 8px;
  }

  .prep-card-img-wrap {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0f0f0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .prep-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prep-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    background: linear-gradient(135deg, #f0f4ff, #f5f5f5);
  }

  .prep-card-body {
    flex: 1;
    min-width: 0;
  }

  .prep-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    line-height: 1.35;
  }

  .prep-card-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  .prep-card-desc {
    font-size: 0.8rem;
    color: #777;
    line-height: 1.5;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prep-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .prep-tag {
    font-size: 0.62rem;
    font-weight: 600;
    color: #888;
    background: #f3f3f3;
    padding: 0.2em 0.55em;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .prep-arrow {
    color: #ccc;
    font-size: 1.1rem;
    transition: color 0.2s, transform 0.2s;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .prep-card:hover .prep-arrow {
    color: #1a73e8;
    transform: translateX(3px);
  }

  /* ===== CTA ===== */
  .prep-cta {
    margin-top: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .prep-cta-btn {
    display: inline-block;
    background: #111;
    color: #fff;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .prep-cta-btn:hover {
    background: #333;
    transform: translateY(-1px);
  }

  .prep-cta-time {
    font-size: 0.85rem;
    color: #999;
  }

  @media (max-width: 640px) {
    .prep-section {
      padding: 0 1rem;
    }
    .prep-body {
      padding: 40px 1rem 50px;
    }
    .prep-grid {
      grid-template-columns: 1fr;
    }
    .prep-card {
      padding: 1.25rem 1rem;
    }
    .prep-card-img-wrap {
      width: 56px;
      height: 56px;
    }
    .prep-toggle-bar-inner {
      padding: 0.85rem 1rem;
      flex-wrap: wrap;
    }
    .prep-toggle-label {
      font-size: 0.9rem;
    }
    .prep-toggle-hint {
      display: none;
    }
  }
</style>

<script>
  // Collapsible toggle — pure vanilla, no hydration needed
  const toggleBar = document.getElementById('prepToggleBar');
  const prepBody = document.getElementById('prepBody');
  const toggleIcon = document.getElementById('prepToggleIcon');
  const toggleHint = document.getElementById('prepToggleHint');
  const toggleLabel = toggleBar?.querySelector('.prep-toggle-label');

  if (toggleBar && prepBody) {
    let isExpanded = true;

    toggleBar.addEventListener('click', () => {
      isExpanded = !isExpanded;
      toggleBar.setAttribute('aria-expanded', String(isExpanded));

      if (isExpanded) {
        prepBody.classList.remove('collapsed');
        if (toggleIcon) toggleIcon.innerHTML = '<svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M1 1L9 9L17 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        if (toggleHint) toggleHint.textContent = 'click to collapse ↑';
        if (toggleLabel) toggleLabel.textContent = '疑难杂症 · Survival Kit';
      } else {
        prepBody.classList.add('collapsed');
        if (toggleIcon) toggleIcon.innerHTML = '<svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M1 1L9 9L17 1" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        if (toggleHint) toggleHint.textContent = 'click to expand ↓';
        if (toggleLabel) toggleLabel.textContent = '疑难杂症 · Survival Kit (收起)';
      }
    });
  }
</script>
