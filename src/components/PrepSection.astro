---
// PrepSection.astro — Dynamic "Before You Land" section
// Renders foreigners survival-kit guides from content collection

export interface Props {
  guides: any[];
}

const { guides } = Astro.props;

// Topic icon map
const topicIcons: Record<string, string> = {
  visa: '🛂',
  entry: '🛂',
  passport: '🛂',
  payment: '💳',
  alipay: '💳',
  wechat: '💳',
  internet: '🌐',
  vpn: '🌐',
  esim: '🌐',
  apps: '📱',
  essential: '📱',
  transport: '🚇',
  metro: '🚇',
  taxi: '🚇',
  health: '🏥',
  emergency: '🏥',
  hospital: '🏥',
  culture: '🎭',
  food: '🎭',
  etiquette: '🎭',
  overview: '📋',
};

function getIcon(guide: any): string {
  const tags = guide.data.tags || [];
  for (const tag of tags) {
    if (topicIcons[tag]) return topicIcons[tag];
  }
  return '📌';
}

// Extract first meaningful paragraph from body
function extractExcerpt(body: string, maxLen = 120): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    // Skip headings, empty lines, images, tables, list items
    if (!trimmed) continue;
    if (trimmed.startsWith('#')) continue;
    if (trimmed.startsWith('![')) continue;
    if (trimmed.startsWith('|')) continue;
    if (trimmed.startsWith('>')) continue;
    if (trimmed.startsWith('-')) continue;
    if (trimmed.startsWith('*')) continue;
    // Got a real paragraph
    const clean = trimmed.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\*\*/g, '');
    if (clean.length > maxLen) return clean.slice(0, maxLen).trimEnd() + '…';
    return clean;
  }
  return '';
}

// Exclude the index/overview page from cards
const displayGuides = guides.filter((g: any) => g.data.pageSlug !== 'foreigners-index');
---

<section class="prep-section">
  <div class="prep-header">
    <p class="prep-eyebrow">BEFORE YOU LAND</p>
    <h2 class="prep-title">疑难杂症 · Survival Kit</h2>
    <p class="prep-subtitle">
      Everything a foreigner needs to know before arriving in China.
      From visas to payments to cultural survival — we've got you covered.
    </p>
  </div>

  <div class="prep-grid">
    {displayGuides.map((guide: any, i: number) => {
      const { title, pageSlug, cover, tags } = guide.data;
      const excerpt = extractExcerpt(guide.body);
      const icon = getIcon(guide);
      const num = String(i + 1).padStart(2, '0');
      return (
        <a href={`/guides/${pageSlug}/`} class="prep-card">
          <span class="prep-num">{num}</span>
          <div class="prep-card-img-wrap">
            {cover ? (
              <img src={cover} alt={title} class="prep-card-img" loading="lazy" />
            ) : (
              <div class="prep-card-img-placeholder">{icon}</div>
            )}
          </div>
          <div class="prep-card-body">
            <h3 class="prep-card-title">
              <span class="prep-card-icon">{icon}</span>
              {title}
            </h3>
            {excerpt && <p class="prep-card-desc">{excerpt}</p>}
            <div class="prep-card-tags">
              {tags.filter((t: string) => t !== 'survival-kit').map((tag: string) => (
                <span class="prep-tag">{tag}</span>
              ))}
            </div>
          </div>
          <span class="prep-arrow">→</span>
        </a>
      );
    })}
  </div>

  <div class="prep-cta">
    <a href="/guides/foreigners/foreigners-index/" class="prep-cta-btn">📋 Full Survival Kit</a>
    <span class="prep-cta-time">⏱️ 7 guides</span>
  </div>
</section>

<style>
  .prep-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 2rem 100px;
  }

  .prep-header {
    text-align: center;
    margin-bottom: 72px;
  }

  .prep-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #999;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .prep-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #111;
    margin-bottom: 1.25rem;
  }

  .prep-subtitle {
    font-size: 1.1rem;
    color: #666;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .prep-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1px;
    background: #e5e5e5;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
  }

  .prep-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 2rem 1.75rem;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
    position: relative;
  }

  .prep-card:hover {
    background: #fafafa;
  }

  .prep-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: #ccc;
    letter-spacing: 0.05em;
    min-width: 28px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .prep-card-img-wrap {
    width: 64px;
    height: 64px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0f0f0;
  }

  .prep-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prep-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: #f5f5f5;
  }

  .prep-card-body {
    flex: 1;
    min-width: 0;
  }

  .prep-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1.3;
  }

  .prep-card-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .prep-card-desc {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.55;
    margin: 0 0 0.6rem;
  }

  .prep-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .prep-tag {
    font-size: 0.65rem;
    font-weight: 600;
    color: #888;
    background: #f0f0f0;
    padding: 0.2em 0.6em;
    border-radius: 4px;
    letter-spacing: 0.03em;
  }

  .prep-arrow {
    color: #ccc;
    font-size: 1.1rem;
    transition: color 0.2s, transform 0.2s;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .prep-card:hover .prep-arrow {
    color: #111;
    transform: translateX(3px);
  }

  .prep-cta {
    margin-top: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .prep-cta-btn {
    display: inline-block;
    background: #111;
    color: #fff;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .prep-cta-btn:hover {
    background: #333;
    transform: translateY(-1px);
  }

  .prep-cta-time {
    font-size: 0.85rem;
    color: #999;
  }


  @media (max-width: 640px) {
    .prep-section {
      padding: 80px 1.25rem 60px;
    }
    .prep-grid {
      grid-template-columns: 1fr;
    }
    .prep-card {
      padding: 1.5rem 1.25rem;
    }
    .prep-card-img-wrap {
      width: 48px;
      height: 48px;
    }
  }
</style>
