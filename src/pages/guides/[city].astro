---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  const cities = [...new Set(guides.map(g => g.data.city))];
  return cities.map(city => ({ params: { city } }));
}

const { city } = Astro.params;
const allGuides = await getCollection('guides', ({ data }) => !data.draft && data.city === city);

const cityNames: Record<string, string> = {
  // Cities
  beijing: 'Beijing · 北京',
  shanghai: 'Shanghai · 上海',
  chongqing: 'Chongqing · 重庆',
  chengdu: 'Chengdu · 成都',
  xian: "Xi'an · 西安",
  hangzhou: 'Hangzhou · 杭州',
  shenzhen: 'Shenzhen · 深圳',
  guangzhou: 'Guangzhou · 广州',
  nanjing: 'Nanjing · 南京',
  qingdao: 'Qingdao · 青岛',
  harbin: 'Harbin · 哈尔滨',
  guiyang: 'Guiyang · 贵阳',
  lhasa: 'Lhasa · 拉萨',
  wuhan: 'Wuhan · 武汉',
  chengde: 'Chengde · 承德',
  dali: 'Dali · 大理',
  lijiang: 'Lijiang · 丽江',
  yangshuo: 'Yangshuo · 阳朔',
  leshan: 'Leshan · 乐山',
  'shangri-la': 'Shangri-La · 香格里拉',
  hohhot: 'Hohhot · 呼和浩特',
  zhangye: 'Zhangye · 张掖',
  datong: 'Datong · 大同',
  kaifeng: 'Kaifeng · 开封',
  sanya: 'Sanya · 三亚',
  dalian: 'Dalian · 大连',
  lanzhou: 'Lanzhou · 兰州',
  suzhou: 'Suzhou · 苏州',
  xiamen: 'Xiamen · 厦门',
  changsha: 'Changsha · 长沙',
  guilin: 'Guilin · 桂林',
  kunming: 'Kunming · 昆明',
  luoyang: 'Luoyang · 洛阳',
  macau: 'Macau · 澳门',
  hongkong: 'Hong Kong · 香港',
  dunhuang: 'Dunhuang · 敦煌',
  huangshan: 'Huangshan · 黄山',
  jiuzhaigou: 'Jiuzhaigou · 九寨沟',
  zhangjiajie: 'Zhangjiajie · 张家界',
  yunnan: 'Yunnan · 云南',
  // Scenic Spots
  changbaishan: 'Changbaishan · 长白山',
  dazu_rock_carvings: 'Dazu Rock Carvings · 大足石刻',
  emeishan: 'Mount Emei · 峨眉山',
  forbidden_city: 'Forbidden City · 故宫',
  great_wall: 'Great Wall · 长城',
  guilin_lijiang: 'Li River · 漓江',
  huangguoshu: 'Huangguoshu Waterfall · 黄果树瀑布',
  longmen_grottoes: 'Longmen Grottoes · 龙门石窟',
  mogao_caves: 'Mogao Caves · 莫高窟',
  potala_palace: 'Potala Palace · 布达拉宫',
  qinghai_lake: 'Qinghai Lake · 青海湖',
  qufu: 'Qufu · 曲阜',
  suzhou_gardens: 'Suzhou Gardens · 苏州园林',
  taishan: 'Mount Tai · 泰山',
  terracotta_warriors: 'Terracotta Warriors · 兵马俑',
  wudang_mountain: 'Wudang Mountain · 武当山',
  wuyishan: 'Wuyishan · 武夷山',
  foreigners: 'Survival Kit · 外国人指南',
};

const displayName = cityNames[city] || city;
const description = `Browse all our ${displayName} travel guides — honest tips from locals and experienced travelers.`;
---

<BaseLayout
  title={`${displayName} Travel Guides`}
  description={description}
>
  <div class="city-page">
    <div class="city-header">
      <a href="/guides/" class="city-back">&larr; All Cities</a>
      <h1 class="city-title">{displayName}</h1>
      <p class="city-count">{allGuides.length} guide{allGuides.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="city-guides">
      {allGuides.length === 0 && (
        <div class="city-empty">
          <p>No guides yet for {displayName}.</p>
          <a href="/guides/" class="city-empty-link">Browse other cities &rarr;</a>
        </div>
      )}
      {allGuides.map(g => (
        <a href={`/guides/${g.data.pageSlug}`} class="guide-card">
          <div class="guide-card-img">
            {g.data.cover ? (
              <img src={g.data.cover} alt={g.data.title} loading="lazy" />
            ) : (
              <div class="guide-card-img-placeholder">
                <span>🏯</span>
              </div>
            )}
          </div>
          <div class="guide-card-body">
            <h2 class="guide-card-title">{g.data.title}</h2>
            <div class="guide-card-meta">
              {g.data.duration && <span class="guide-card-duration">⏱ {g.data.duration}</span>}
            </div>
            {g.data.tags && g.data.tags.length > 0 && (
              <div class="guide-card-tags">
                {g.data.tags.map(t => <span class="guide-card-tag">{t}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .city-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .city-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #f0f0f0;
  }

  .city-back {
    display: inline-block;
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 1rem;
    transition: color 0.2s;
  }

  .city-back:hover {
    color: #333;
    text-decoration: none;
  }

  .city-title {
    font-size: 2.2rem;
    font-weight: 900;
    color: #111;
    margin-bottom: 0.35rem;
    letter-spacing: -0.02em;
  }

  .city-count {
    font-size: 1rem;
    color: #888;
  }

  /* === Xiaohongshu-style Card Grid === */
  .city-guides {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .guide-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
    text-decoration: none;
  }

  .guide-card-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f0f0f0;
    position: relative;
  }

  .guide-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .guide-card:hover .guide-card-img img {
    transform: scale(1.04);
  }

  .guide-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f0eb 0%, #e8e0d5 100%);
    font-size: 3rem;
  }

  .guide-card-body {
    padding: 1rem 1.1rem 1.1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .guide-card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a1a2e;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .guide-card-meta {
    display: flex;
    align-items: center;
  }

  .guide-card-duration {
    font-size: 0.82rem;
    color: #999;
  }

  .guide-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.35rem;
  }

  .guide-card-tag {
    font-size: 0.7rem;
    background: #f5f0eb;
    color: #8b7355;
    padding: 0.2rem 0.6rem;
    border-radius: 10px;
    font-weight: 500;
  }

  .city-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: #999;
  }

  .city-empty p {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .city-empty-link {
    color: #e63946;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .city-guides {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .guide-card-body {
      padding: 0.7rem 0.8rem 0.8rem;
    }
    .guide-card-title {
      font-size: 0.9rem;
    }
    .city-title {
      font-size: 1.6rem;
    }
  }
</style>
